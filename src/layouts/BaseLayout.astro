---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  lang?: 'zh' | 'en';
  path?: 'home' | 'writing' | 'research' | 'projects' | 'ai-news' | 'about' | 'resume';
  switchTo?: string;
  showLanguageSwitch?: boolean;
  image?: string;
  publishedTime?: string;
}

const {
  title,
  description = 'Ryanyx writes about AI, investing, finance, and small tools.',
  lang = 'zh',
  path = 'home',
  switchTo,
  showLanguageSwitch = true,
  image,
  publishedTime
} = Astro.props;

const isEn = lang === 'en';
const nav = isEn
  ? [
      ['Home', '/en/'],
      ['Writing', '/en/writing/'],
      ['Research', '/en/research/'],
      ['Projects', '/en/projects/'],
      ['AI News', '/ai-news/'],
      ['About', '/en/about/'],
      ['Resume', '/en/resume/']
    ]
  : [
      ['首页', '/'],
      ['文章', '/writing/'],
      ['投研', '/research/'],
      ['项目', '/projects/'],
      ['AI 资讯', '/ai-news/'],
      ['关于', '/about/'],
      ['简历', '/resume/']
    ];

const counterpartMap = {
  home: isEn ? '/' : '/en/',
  writing: isEn ? '/writing/' : '/en/writing/',
  research: isEn ? '/research/' : '/en/research/',
  projects: isEn ? '/projects/' : '/en/projects/',
  'ai-news': '/ai-news/',
  about: isEn ? '/about/' : '/en/about/',
  resume: isEn ? '/resume/' : '/en/resume/'
};

const langHref = switchTo ?? counterpartMap[path];
const langLabel = isEn ? '中文' : 'EN';
const fullTitle = title === 'Ryanyx' ? 'Ryanyx' : `${title} · Ryanyx`;
const canonicalURL = Astro.site ? new URL(Astro.url.pathname, Astro.site) : Astro.url;
const imageURL = image ? new URL(image, canonicalURL) : undefined;
---
<!doctype html>
<html lang={isEn ? 'en' : 'zh-CN'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:type" content={publishedTime ? 'article' : 'website'} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="Ryanyx" />
    <meta property="og:locale" content={isEn ? 'en_US' : 'zh_CN'} />
    {imageURL && <meta property="og:image" content={imageURL} />}
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    <meta name="twitter:card" content={imageURL ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    {imageURL && <meta name="twitter:image" content={imageURL} />}
    <title>{fullTitle}</title>
    <link rel="icon" href="/favicon.svg" />
    <script is:inline>
      (() => {
        const choice = localStorage.getItem('theme') || 'system';
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const resolved = choice === 'system' ? (prefersDark ? 'dark' : 'light') : choice;
        document.documentElement.dataset.theme = resolved;
      })();
    </script>
  </head>
  <body>
    <header class="site-header">
      <div class="shell nav-bar">
        <a class="brand" href={isEn ? '/en/' : '/'}>Ryanyx</a>
        <nav class="nav-links" aria-label={isEn ? 'Main navigation' : '主导航'}>
          {nav.map(([label, href]) => <a href={href}>{label}</a>)}
        </nav>
        <div class="nav-actions">
          {showLanguageSwitch && <a class="pill-button" href={langHref} aria-label={isEn ? '切换到中文' : 'Switch to English'}>{langLabel}</a>}
          <button class="pill-button theme-toggle" type="button" aria-label={isEn ? 'Toggle color mode' : '切换亮色或暗色模式'}>◐</button>
        </div>
      </div>
    </header>
    <main class="shell">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="shell footer-inner">
        <span>© {new Date().getFullYear()} Ryanyx</span>
        <span>{isEn ? 'Finance, AI engineering, investing, and small tools.' : '金融、AI 工程实践、投资思考和小工具。'}</span>
      </div>
    </footer>
    <div
      class="like-widget"
      data-like-widget
      data-page-key={Astro.url.pathname}
      data-like-label={isEn ? 'Like this page' : '喜欢这个页面'}
      data-liked-label={isEn ? 'You liked this page' : '你已赞过这个页面'}
      data-thanks={isEn ? 'Thanks for the love' : '谢谢喜欢'}
    >
      <button class="like-button" type="button" aria-pressed="false" aria-label={isEn ? 'Like this page' : '喜欢这个页面'}>
        <span class="like-heart" aria-hidden="true">♥</span>
        <span class="like-count" aria-label={isEn ? 'Loading like count' : '正在加载点赞数'}>—</span>
      </button>
      <span class="like-status" role="status" aria-live="polite"></span>
    </div>
    <script is:inline>
      (() => {
        const button = document.querySelector('.theme-toggle');
        const media = window.matchMedia('(prefers-color-scheme: dark)');
        const getChoice = () => localStorage.getItem('theme') || 'system';
        const resolve = (choice) => choice === 'system' ? (media.matches ? 'dark' : 'light') : choice;
        const apply = (choice) => {
          document.documentElement.dataset.theme = resolve(choice);
          if (button) button.textContent = resolve(choice) === 'dark' ? '☾' : '☼';
        };

        button?.addEventListener('click', () => {
          const next = resolve(getChoice()) === 'dark' ? 'light' : 'dark';
          localStorage.setItem('theme', next);
          apply(next);
        });
        media.addEventListener('change', () => {
          if (getChoice() === 'system') apply('system');
        });
        apply(getChoice());
      })();
    </script>
    <script is:inline>
      (() => {
        const widget = document.querySelector('[data-like-widget]');
        if (!widget) return;

        const button = widget.querySelector('.like-button');
        const count = widget.querySelector('.like-count');
        const status = widget.querySelector('.like-status');
        const pageKey = widget.dataset.pageKey;
        const storageKey = `ryanzr:liked:${pageKey}`;
        const hasLiked = () => localStorage.getItem(storageKey) === '1';

        const setLikedState = (liked) => {
          button.classList.toggle('is-liked', liked);
          button.setAttribute('aria-pressed', String(liked));
          button.setAttribute('aria-label', liked ? widget.dataset.likedLabel : widget.dataset.likeLabel);
        };

        const burst = () => {
          widget.classList.remove('is-bursting');
          void widget.offsetWidth;
          widget.classList.add('is-bursting');
          const floater = document.createElement('span');
          floater.className = 'like-floater';
          floater.setAttribute('aria-hidden', 'true');
          floater.textContent = '♥';
          widget.append(floater);
          floater.addEventListener('animationend', () => floater.remove(), { once: true });
        };

        const loadCount = async () => {
          try {
            const response = await fetch(`/api/likes?key=${encodeURIComponent(pageKey)}`, {
              headers: { Accept: 'application/json' }
            });
            if (!response.ok) throw new Error('Unable to load likes');
            const data = await response.json();
            count.textContent = new Intl.NumberFormat(document.documentElement.lang).format(data.count);
            count.setAttribute('aria-label', `${data.count} likes`);
          } catch {
            count.textContent = '♡';
          }
        };

        setLikedState(hasLiked());
        loadCount();

        button.addEventListener('click', async () => {
          burst();
          if (hasLiked() || button.disabled) return;

          button.disabled = true;
          try {
            const response = await fetch('/api/likes', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
              body: JSON.stringify({ key: pageKey })
            });
            if (!response.ok) throw new Error('Unable to save like');
            const data = await response.json();
            localStorage.setItem(storageKey, '1');
            setLikedState(true);
            count.textContent = new Intl.NumberFormat(document.documentElement.lang).format(data.count);
            count.setAttribute('aria-label', `${data.count} likes`);
            status.textContent = widget.dataset.thanks;
            window.setTimeout(() => { status.textContent = ''; }, 1800);
          } catch {
            status.textContent = document.documentElement.lang === 'en' ? 'Please try again' : '暂时没点上，请稍后再试';
          } finally {
            button.disabled = false;
          }
        });
      })();
    </script>
  </body>
</html>
