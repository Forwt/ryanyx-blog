---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  lang?: 'zh' | 'en';
  path?: 'home' | 'writing' | 'research' | 'second-brain' | 'projects' | 'ai-news' | 'about' | 'resume';
  switchTo?: string;
  showLanguageSwitch?: boolean;
  image?: string;
  publishedTime?: string;
}

const {
  title,
  description = 'Ryanyx writes about AI, investing, finance, and small tools.',
  lang = 'zh',
  path = 'home',
  switchTo,
  showLanguageSwitch = true,
  image,
  publishedTime
} = Astro.props;

const isEn = lang === 'en';
const nav = isEn
  ? [
      ['Home', '/en/'],
      ['Writing', '/en/writing/'],
      ['Research', '/en/research/'],
      ['Second Brain', '/en/second-brain/'],
      ['Projects', '/en/projects/'],
      ['AI News', '/en/ai-news/'],
      ['About', '/en/about/'],
      ['Resume', '/en/resume/']
    ]
  : [
      ['首页', '/'],
      ['文章', '/writing/'],
      ['投研', '/research/'],
      ['第二大脑', '/second-brain/'],
      ['项目', '/projects/'],
      ['AI 资讯', '/ai-news/'],
      ['关于', '/about/'],
      ['简历', '/resume/']
    ];

const counterpartMap = {
  home: isEn ? '/' : '/en/',
  writing: isEn ? '/writing/' : '/en/writing/',
  research: isEn ? '/research/' : '/en/research/',
  'second-brain': isEn ? '/second-brain/' : '/en/second-brain/',
  projects: isEn ? '/projects/' : '/en/projects/',
  'ai-news': isEn ? '/ai-news/' : '/en/ai-news/',
  about: isEn ? '/about/' : '/en/about/',
  resume: isEn ? '/resume/' : '/en/resume/'
};

const langHref = switchTo ?? counterpartMap[path];
const langLabel = isEn ? '中文' : 'EN';
const fullTitle = title === 'Ryanyx' ? 'Ryanyx' : `${title} · Ryanyx`;
const isSecondBrain = path === 'second-brain';
const canonicalURL = Astro.site ? new URL(Astro.url.pathname, Astro.site) : Astro.url;
const imageURL = image ? new URL(image, canonicalURL) : undefined;
const editorCopy = isEn
  ? {
      open: 'Edit text',
      heading: 'Editing mode',
      description: 'Enter the password to edit this page locally.',
      password: 'Password',
      enter: 'Start editing',
      cancel: 'Cancel',
      error: 'That password is not correct.',
      active: 'Editing',
      changes: 'changes',
      export: 'Exit & download record',
      reset: 'Clear this page draft',
      note: 'Changes are stored only in this browser until you download the record.',
      empty: 'No text blocks changed yet.',
      exported: 'The change record has been downloaded.',
      resetDone: 'The local draft has been cleared.'
    }
  : {
      open: '编辑文字',
      heading: '编辑模式',
      description: '输入密码后可在当前浏览器直接修改本页正文。',
      password: '密码',
      enter: '开始编辑',
      cancel: '取消',
      error: '密码不正确，请再试一次。',
      active: '正在编辑',
      changes: '处修改',
      export: '退出并下载修改记录',
      reset: '清除本页草稿',
      note: '修改只保存在当前浏览器，下载记录后发给我即可正式回填。',
      empty: '暂时还没有文字修改。',
      exported: '修改记录已下载。',
      resetDone: '本页浏览器草稿已清除。'
    };
---
<!doctype html>
<html lang={isEn ? 'en' : 'zh-CN'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:type" content={publishedTime ? 'article' : 'website'} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="Ryanyx" />
    <meta property="og:locale" content={isEn ? 'en_US' : 'zh_CN'} />
    {imageURL && <meta property="og:image" content={imageURL} />}
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    <meta name="twitter:card" content={imageURL ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    {imageURL && <meta name="twitter:image" content={imageURL} />}
    <title>{fullTitle}</title>
    <link rel="icon" href="/favicon.svg" />
    <script is:inline>
      (() => {
        const choice = localStorage.getItem('theme') || 'system';
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const resolved = choice === 'system' ? (prefersDark ? 'dark' : 'light') : choice;
        document.documentElement.dataset.theme = resolved;
      })();
    </script>
    {isSecondBrain && <script is:inline>
      (() => {
        try {
          if (sessionStorage.getItem('ryanzr:second-brain:unlocked') === '1') {
            document.documentElement.dataset.secondBrainUnlocked = 'true';
          }
        } catch {}
      })();
    </script>}
  </head>
  <body data-second-brain-protected={isSecondBrain ? 'true' : undefined}>
    {isSecondBrain && <div class="access-gate" data-access-gate>
      <div class="access-gate-card">
        <div class="eyebrow">{isEn ? 'Private area' : 'Private area / 私人区域'}</div>
        <h1>{isEn ? 'Second Brain' : '第二大脑'}</h1>
        <p>{isEn ? 'Enter the password to continue.' : '这是一个私人板块，请输入密码后继续。'}</p>
        <form data-access-form>
          <label for="second-brain-password">{isEn ? 'Password' : '密码'}</label>
          <input id="second-brain-password" data-access-input type="password" inputmode="numeric" autocomplete="current-password" maxlength="4" required />
          <button class="pill-button access-submit" type="submit">{isEn ? 'Enter' : '进入'}</button>
          <p class="access-error" data-access-error role="status" aria-live="polite"></p>
        </form>
      </div>
    </div>}
    <header class="site-header">
      <div class="shell nav-bar">
        <a class="brand" href={isEn ? '/en/' : '/'}>Ryanyx</a>
        <nav class="nav-links" aria-label={isEn ? 'Main navigation' : '主导航'}>
          {nav.map(([label, href]) => <a href={href}>{label}</a>)}
        </nav>
        <div class="nav-actions">
          {showLanguageSwitch && <a class="pill-button" href={langHref} aria-label={isEn ? '切换到中文' : 'Switch to English'}>{langLabel}</a>}
          <button class="pill-button theme-toggle" type="button" aria-label={isEn ? 'Toggle color mode' : '切换亮色或暗色模式'}>◐</button>
        </div>
      </div>
    </header>
    <main class="shell" data-protected-content={isSecondBrain ? 'true' : undefined}>
      <slot />
    </main>
    <aside
      class="editor-widget"
      data-editor-widget
      data-page-key={Astro.url.pathname}
      data-page-title={title}
      data-editor-empty={editorCopy.empty}
      data-editor-exported={editorCopy.exported}
      data-editor-reset-done={editorCopy.resetDone}
    >
      <button class="editor-open" data-editor-open type="button" aria-haspopup="dialog" aria-controls="editor-gate">{editorCopy.open}</button>
      <div class="editor-gate" data-editor-gate id="editor-gate" role="dialog" aria-modal="true" aria-labelledby="editor-gate-title" hidden>
        <form class="editor-gate-card" data-editor-form>
          <div class="eyebrow">RYANYX / {editorCopy.heading}</div>
          <h2 id="editor-gate-title">{editorCopy.heading}</h2>
          <p>{editorCopy.description}</p>
          <label for="editor-password">{editorCopy.password}</label>
          <input id="editor-password" data-editor-input type="password" inputmode="numeric" autocomplete="current-password" maxlength="4" required />
          <p class="editor-error" data-editor-error role="status" aria-live="polite"></p>
          <div class="editor-gate-actions">
            <button class="pill-button" type="submit">{editorCopy.enter}</button>
            <button class="editor-text-button" data-editor-cancel type="button">{editorCopy.cancel}</button>
          </div>
        </form>
      </div>
      <div class="editor-active-controls" data-editor-controls hidden>
        <div>
          <span class="editor-live-label">{editorCopy.active}</span>
          <strong data-editor-count>0 {editorCopy.changes}</strong>
        </div>
        <button class="editor-export" data-editor-export type="button">{editorCopy.export}</button>
        <button class="editor-reset" data-editor-reset type="button">{editorCopy.reset}</button>
        <p data-editor-status role="status" aria-live="polite">{editorCopy.note}</p>
      </div>
    </aside>
    <footer class="site-footer">
      <div class="shell footer-inner">
        <span>© {new Date().getFullYear()} Ryanyx</span>
        <span>{isEn ? 'Finance, AI engineering, investing, and small tools.' : '金融、AI 工程实践、投资思考和小工具。'}</span>
      </div>
    </footer>
    <div
      class="like-widget"
      data-like-widget
      data-page-key={Astro.url.pathname}
      data-like-label={isEn ? 'Like this page' : '喜欢这个页面'}
      data-liked-label={isEn ? 'You liked this page' : '你已赞过这个页面'}
      data-thanks={isEn ? 'Thanks for the love' : '谢谢喜欢'}
    >
      <button class="like-button" type="button" aria-pressed="false" aria-label={isEn ? 'Like this page' : '喜欢这个页面'}>
        <span class="like-heart" aria-hidden="true">♥</span>
        <span class="like-count" aria-label={isEn ? 'Loading like count' : '正在加载点赞数'}>—</span>
      </button>
      <span class="like-status" role="status" aria-live="polite"></span>
    </div>
    {isSecondBrain && <script is:inline>
      (() => {
        const gate = document.querySelector('[data-access-gate]');
        const form = document.querySelector('[data-access-form]');
        const input = document.querySelector('[data-access-input]');
        const error = document.querySelector('[data-access-error]');
        if (!gate || !form || !input || !error) return;

        if (document.documentElement.dataset.secondBrainUnlocked !== 'true') input.focus();

        form.addEventListener('submit', (event) => {
          event.preventDefault();
          if (input.value.trim() !== '0019') {
            error.textContent = document.documentElement.lang === 'en' ? 'That password is not correct.' : '密码不正确，请再试一次。';
            input.select();
            return;
          }
          try { sessionStorage.setItem('ryanzr:second-brain:unlocked', '1'); } catch {}
          document.documentElement.dataset.secondBrainUnlocked = 'true';
          input.value = '';
          error.textContent = '';
        });
      })();
    </script>}
    <script is:inline>
      (() => {
        const button = document.querySelector('.theme-toggle');
        const media = window.matchMedia('(prefers-color-scheme: dark)');
        const getChoice = () => localStorage.getItem('theme') || 'system';
        const resolve = (choice) => choice === 'system' ? (media.matches ? 'dark' : 'light') : choice;
        const apply = (choice) => {
          document.documentElement.dataset.theme = resolve(choice);
          if (button) button.textContent = resolve(choice) === 'dark' ? '☾' : '☼';
        };

        button?.addEventListener('click', () => {
          const next = resolve(getChoice()) === 'dark' ? 'light' : 'dark';
          localStorage.setItem('theme', next);
          apply(next);
        });
        media.addEventListener('change', () => {
          if (getChoice() === 'system') apply('system');
        });
        apply(getChoice());
      })();
    </script>
    <script is:inline>
      (() => {
        const widget = document.querySelector('[data-editor-widget]');
        const main = document.querySelector('main.shell');
        if (!widget || !main) return;

        const open = widget.querySelector('[data-editor-open]');
        const gate = widget.querySelector('[data-editor-gate]');
        const form = widget.querySelector('[data-editor-form]');
        const input = widget.querySelector('[data-editor-input]');
        const error = widget.querySelector('[data-editor-error]');
        const cancel = widget.querySelector('[data-editor-cancel]');
        const controls = widget.querySelector('[data-editor-controls]');
        const count = widget.querySelector('[data-editor-count]');
        const exportButton = widget.querySelector('[data-editor-export]');
        const resetButton = widget.querySelector('[data-editor-reset]');
        const status = widget.querySelector('[data-editor-status]');
        const pageKey = widget.dataset.pageKey || window.location.pathname;
        const storageKey = `ryanyx:editor-draft:${pageKey}`;
        const getText = (element) => element.innerText.replace(/\u00a0/g, ' ').replace(/\n{3,}/g, '\n\n').trim();
        const candidates = Array.from(main.querySelectorAll('article h1, article h2, article h3, article h4, article p, article li, article blockquote'))
          .filter((element) => {
            if (!getText(element)) return false;
            if (element.closest('a, button, pre, code, [data-inspiration-demo], .editor-widget, .like-widget')) return false;
            if (element.tagName === 'P' && element.parentElement?.closest('blockquote, li')) return false;
            if (element.tagName === 'LI' && element.parentElement?.closest('li')) return false;
            return true;
          });

        const targets = candidates.map((element, index) => {
          const target = element;
          const originalText = getText(target);
          const originalHTML = target.innerHTML;
          const article = target.closest('article');
          const section = article?.className || 'article';
          const id = `${index + 1}-${target.tagName.toLowerCase()}`;
          target.dataset.editorTarget = id;
          return { target, id, originalText, originalHTML, section };
        });

        let active = false;
        let draft = { version: 1, startedAt: '', updatedAt: '', changes: {} };

        const readDraft = () => {
          try {
            const saved = JSON.parse(localStorage.getItem(storageKey) || 'null');
            if (saved && saved.version === 1 && saved.changes) return saved;
          } catch {}
          return { version: 1, startedAt: '', updatedAt: '', changes: {} };
        };
        const saveDraft = () => {
          draft.updatedAt = new Date().toISOString();
          try { localStorage.setItem(storageKey, JSON.stringify(draft)); } catch {}
        };
        const changedTargets = () => targets.filter(({ id, originalText }) => {
          const revisedText = draft.changes[id]?.revisedText ?? originalText;
          return revisedText !== originalText;
        });
        const updateCount = () => {
          if (count) count.textContent = `${changedTargets().length} ${document.documentElement.lang === 'en' ? 'changes' : '处修改'}`;
        };
        const restoreOriginals = () => {
          targets.forEach(({ target, originalHTML }) => {
            target.innerHTML = originalHTML;
            target.removeAttribute('contenteditable');
            target.removeAttribute('spellcheck');
          });
        };
        const recordChange = (entry) => {
          const revisedText = getText(entry.target);
          if (revisedText === entry.originalText) delete draft.changes[entry.id];
          else {
            draft.changes[entry.id] = {
              target: entry.id,
              section: entry.section,
              tag: entry.target.tagName.toLowerCase(),
              originalText: entry.originalText,
              revisedText,
              lastModifiedAt: new Date().toISOString()
            };
          }
          saveDraft();
          updateCount();
        };
        const activate = () => {
          active = true;
          draft = readDraft();
          if (!draft.startedAt) draft.startedAt = new Date().toISOString();
          targets.forEach((entry) => {
            const savedText = draft.changes[entry.id]?.revisedText;
            if (typeof savedText === 'string') entry.target.textContent = savedText;
            entry.target.setAttribute('contenteditable', 'true');
            entry.target.setAttribute('spellcheck', 'true');
          });
          document.documentElement.dataset.editorActive = 'true';
          open.hidden = true;
          controls.hidden = false;
          status.textContent = document.documentElement.lang === 'en'
            ? 'Edit the highlighted text. Your draft is saved in this browser.'
            : '可直接修改高亮文字；草稿会保存在当前浏览器。';
          updateCount();
        };
        const deactivate = () => {
          active = false;
          restoreOriginals();
          delete document.documentElement.dataset.editorActive;
          controls.hidden = true;
          open.hidden = false;
        };
        const openGate = () => {
          gate.hidden = false;
          error.textContent = '';
          window.setTimeout(() => input.focus(), 0);
        };
        const closeGate = () => {
          gate.hidden = true;
          input.value = '';
          error.textContent = '';
          open.focus();
        };
        const downloadRecord = () => {
          const changes = changedTargets().map(({ id, section, target, originalText }) => ({
            target: id,
            section,
            tag: target.tagName.toLowerCase(),
            originalText,
            revisedText: draft.changes[id].revisedText,
            lastModifiedAt: draft.changes[id].lastModifiedAt
          }));
          const record = {
            format: 'ryanyx-editor-change-set/v1',
            exportedAt: new Date().toISOString(),
            page: { url: window.location.href, title: widget.dataset.pageTitle || document.title, language: document.documentElement.lang },
            changes,
            note: 'Send this file to Codex to apply these text changes to the source repository.'
          };
          const blob = new Blob([JSON.stringify(record, null, 2)], { type: 'application/json;charset=utf-8' });
          const link = document.createElement('a');
          const filename = `ryanyx-edit-log-${new Date().toISOString().replace(/[:.]/g, '-').slice(0, 19)}.json`;
          link.href = URL.createObjectURL(blob);
          link.download = filename;
          link.click();
          URL.revokeObjectURL(link.href);
        };

        targets.forEach((entry) => entry.target.addEventListener('input', () => {
          if (active) recordChange(entry);
        }));
        open.addEventListener('click', openGate);
        cancel.addEventListener('click', closeGate);
        form.addEventListener('submit', (event) => {
          event.preventDefault();
          if (input.value.trim() !== '0019') {
            error.textContent = document.documentElement.lang === 'en' ? 'That password is not correct.' : '密码不正确，请再试一次。';
            input.select();
            return;
          }
          closeGate();
          activate();
        });
        exportButton.addEventListener('click', () => {
          downloadRecord();
          deactivate();
          open.focus();
        });
        resetButton.addEventListener('click', () => {
          draft = { version: 1, startedAt: new Date().toISOString(), updatedAt: '', changes: {} };
          try { localStorage.removeItem(storageKey); } catch {}
          restoreOriginals();
          targets.forEach(({ target }) => {
            target.setAttribute('contenteditable', 'true');
            target.setAttribute('spellcheck', 'true');
          });
          status.textContent = widget.dataset.editorResetDone;
          updateCount();
        });
      })();
    </script>
    <script is:inline>
      (() => {
        const widget = document.querySelector('[data-like-widget]');
        if (!widget) return;

        const button = widget.querySelector('.like-button');
        const count = widget.querySelector('.like-count');
        const status = widget.querySelector('.like-status');
        const pageKey = widget.dataset.pageKey;
        const storageKey = `ryanzr:liked:${pageKey}`;
        const hasLiked = () => localStorage.getItem(storageKey) === '1';

        const setLikedState = (liked) => {
          button.classList.toggle('is-liked', liked);
          button.setAttribute('aria-pressed', String(liked));
          button.setAttribute('aria-label', liked ? widget.dataset.likedLabel : widget.dataset.likeLabel);
        };

        const burst = () => {
          widget.classList.remove('is-bursting');
          void widget.offsetWidth;
          widget.classList.add('is-bursting');
          const floater = document.createElement('span');
          floater.className = 'like-floater';
          floater.setAttribute('aria-hidden', 'true');
          floater.textContent = '♥';
          widget.append(floater);
          floater.addEventListener('animationend', () => floater.remove(), { once: true });
        };

        const loadCount = async () => {
          try {
            const response = await fetch(`/api/likes?key=${encodeURIComponent(pageKey)}`, {
              headers: { Accept: 'application/json' }
            });
            if (!response.ok) throw new Error('Unable to load likes');
            const data = await response.json();
            count.textContent = new Intl.NumberFormat(document.documentElement.lang).format(data.count);
            count.setAttribute('aria-label', `${data.count} likes`);
          } catch {
            count.textContent = '♡';
          }
        };

        setLikedState(hasLiked());
        loadCount();

        button.addEventListener('click', async () => {
          burst();
          if (hasLiked() || button.disabled) return;

          button.disabled = true;
          try {
            const response = await fetch('/api/likes', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
              body: JSON.stringify({ key: pageKey })
            });
            if (!response.ok) throw new Error('Unable to save like');
            const data = await response.json();
            localStorage.setItem(storageKey, '1');
            setLikedState(true);
            count.textContent = new Intl.NumberFormat(document.documentElement.lang).format(data.count);
            count.setAttribute('aria-label', `${data.count} likes`);
            status.textContent = widget.dataset.thanks;
            window.setTimeout(() => { status.textContent = ''; }, 1800);
          } catch {
            status.textContent = document.documentElement.lang === 'en' ? 'Please try again' : '暂时没点上，请稍后再试';
          } finally {
            button.disabled = false;
          }
        });
      })();
    </script>
  </body>
</html>
