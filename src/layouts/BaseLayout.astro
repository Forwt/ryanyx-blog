---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  lang?: 'zh' | 'en';
  switchTo?: string;
}

const {
  title,
  description = 'Ryanzr writes about AI agents, markets, and tools.',
  lang = 'zh',
  switchTo
} = Astro.props;

const isEn = lang === 'en';
const prefix = isEn ? '/en' : '';
const nav = isEn
  ? [
      ['Writing', `${prefix}/writing/`],
      ['Projects', `${prefix}/projects/`],
      ['Resume', `${prefix}/resume/`],
      ['About', `${prefix}/about/`]
    ]
  : [
      ['文章', '/writing/'],
      ['项目', '/projects/'],
      ['简历', '/resume/'],
      ['关于', '/about/']
    ];

const langHref = switchTo ?? (isEn ? '/' : '/en/');
const langLabel = isEn ? '中文' : 'English';
const fullTitle = title.includes('Ryanzr') ? title : `${title} · Ryanzr`;
---
<!doctype html>
<html lang={isEn ? 'en' : 'zh-CN'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{fullTitle}</title>
    <link rel="icon" href="/favicon.svg" />
  </head>
  <body>
    <header class="site-header">
      <div class="site-shell navbar">
        <a class="brand" href={isEn ? '/en/' : '/'}>Ryanzr / AI · Markets · Tools</a>
        <nav class="nav-links" aria-label="Main navigation">
          {nav.map(([label, href]) => <a href={href}>{label}</a>)}
          <a class="lang-switch" href={langHref}>{langLabel}</a>
        </nav>
      </div>
    </header>
    <main class="site-shell">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="site-shell">
        © {new Date().getFullYear()} Ryanzr. Built with Astro, Markdown, GitHub, and Cloudflare Pages.
      </div>
    </footer>
  </body>
</html>
