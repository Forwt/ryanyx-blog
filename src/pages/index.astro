---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import graphData from '../data/second-brain.json';

const posts = (await getCollection('writing', ({ data }) => data.lang === 'zh' && data.draft !== true))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const latestResearch = (await getCollection('research', ({ data }) => data.lang === 'zh' && data.draft !== true))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())[0];

const projects = [
  {
    name: 'AlphaOS 智能投研系统',
    summary: '围绕基煜基金机构服务场景设计的 AI 基金投研工作台，连接基金一页纸、内部资料 RAG、多 Agent 投委会和投资记忆。',
    stack: ['Multi-Agent', 'RAG', 'FinTech'],
    status: 'Live',
    href: '/projects/alphaos/'
  },
  {
    name: '一句话记账',
    summary: '自然语言记账与分账工具，把日常消费记录变成轻量、可复盘的数据。',
    stack: ['AI', 'Personal finance', 'Tooling'],
    status: 'Prototype',
    href: '/projects/one-sentence-ledger/'
  },
  {
    name: 'OpenClaw Agent',
    summary: '基于 LangChain / ReAct 的本地 AI Agent 实践，关注工具调用、权限边界和任务执行。',
    stack: ['LangChain', 'ReAct', 'Agent'],
    status: 'Building',
    href: '/projects/openclaw-agent/'
  },
  {
    name: 'Personal Blog',
    summary: '用 Astro、Markdown、GitHub 和 Cloudflare Pages 搭建的个人知识站。',
    stack: ['Astro', 'Markdown', 'Cloudflare'],
    status: 'Live',
    href: '/projects/personal-blog/'
  }
];
---
<BaseLayout title="Ryanyx" description="Ryan 的个人知识站：AI、投资、金融和小工具。" lang="zh" path="home">
  <section class="hero">
    <div class="eyebrow">AI · Investing · Finance · Small Tools</div>
    <h1>这里是 Ryan Wang 的 blog ，记录一切值得记录的想法。</h1>
    <p class="lead">个人知识站。它用来沉淀文章、项目和长期思考。</p>
  </section>

  <section class="section">
    <div class="section-head">
      <h2>精选文章</h2>
      <a class="section-link" href="/writing/">全部文章</a>
    </div>
    <div class="stack">
      {posts.map((post) => (
        <article class="post-row">
          <div class="meta">{post.data.pubDate.toISOString().slice(0, 10)}</div>
          <a href={`/writing/${post.data.routeSlug}/`}>{post.data.title}</a>
          <p>{post.data.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section ai-news-preview">
    <div class="section-head">
      <h2>AI 资讯 Agent</h2>
      <a class="section-link" href="/ai-news/">查看今日 5 条</a>
    </div>
    <p class="muted">每天自动筛选全球 AI 行业最值得看的 5 条新闻：官方发布、模型进展、产品实验、创业公司动态和有趣的新工具。</p>
  </section>

  <section class="section second-brain-preview">
    <div class="section-head">
      <h2>第二大脑</h2>
      <a class="section-link" href="/second-brain/">进入图谱</a>
    </div>
    <p class="muted">把来自 Obsidian 的 {graphData.stats.notes} 篇笔记放进一张可漫游的地图：目录、主题、标签和手工链接都能成为连接。</p>
    <div class="brain-preview-stats">
      <span><strong>{graphData.stats.notes}</strong> 节点</span>
      <span><strong>{graphData.stats.edges}</strong> 连接</span>
      <span><strong>{graphData.stats.topics}</strong> 共同主题</span>
    </div>
  </section>

  {latestResearch && (
    <section class="section">
      <div class="section-head">
        <h2>精选投研</h2>
        <a class="section-link" href="/research/">进入投研</a>
      </div>
      <article class="research-card research-card-featured">
        <div class="meta">
          {latestResearch.data.pubDate.toISOString().slice(0, 10)} · {latestResearch.data.subject}
        </div>
        <a class="research-card-title" href={`/research/${latestResearch.data.routeSlug}/`}>{latestResearch.data.title}</a>
        <p>{latestResearch.data.description}</p>
        <div class="tags">{latestResearch.data.tags.map((tag) => <span class="tag">{tag}</span>)}</div>
      </article>
    </section>
  )}

  <section class="section">
    <div class="section-head">
      <h2>项目</h2>
      <a class="section-link" href="/projects/">全部项目</a>
    </div>
    <div class="project-grid">
      {projects.map((project) => (
        <a class="project-card project-card-link" href={project.href}>
          <div class="project-top">
            <h3>{project.name}</h3>
            <span class="project-status">{project.status}</span>
          </div>
          <p>{project.summary}</p>
          <div class="tags">{project.stack.map((item) => <span class="tag">{item}</span>)}</div>
        </a>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-head">
      <h2>联系 / 链接</h2>
    </div>
    <div class="link-list">
      <a href="/resume/">简历</a>
      <a href="/about/">关于</a>
    </div>
  </section>
</BaseLayout>
