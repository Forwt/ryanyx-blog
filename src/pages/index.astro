---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('writing', ({ data }) => data.lang === 'zh' && data.draft !== true))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---
<BaseLayout
  title="Ryanzr"
  description="王宇新的个人博客：AI Agent、投资研究与工具系统。"
  lang="zh"
  switchTo="/en/"
>
  <section class="hero">
    <div>
      <div class="eyebrow">Personal notes from Beijing / Hong Kong</div>
      <h1>AI Agent、投资研究与工具系统。</h1>
      <p class="lead">我是王宇新。这里记录我对 AI Agent、市场、金融职业路径和个人工具的长期思考。中文部分是我的原生手写，英文部分会作为 AI 翻译版本同步发布。</p>
    </div>
    <aside class="aside-card">
      /now<br />
      正在关注：AI Agent 工程化、一级投资面试、港美股估值、个人知识系统。<br /><br />
      This site is the archive. Distribution happens on WeChat, Zhihu, Juejin, LinkedIn and GitHub.
    </aside>
  </section>

  <section class="grid">
    <div class="card">
      <h3>Writing</h3>
      <p>长文、复盘和公开笔记。适合沉淀我的判断，而不是追逐平台流量。</p>
    </div>
    <div class="card">
      <h3>Projects</h3>
      <p>OpenClaw、市场资金监测系统、AI 工具实验。证明我真的动手做过。</p>
    </div>
    <div class="card">
      <h3>Resume</h3>
      <p>面向香港买方、AI 投资与金融科技岗位的个人材料入口。</p>
    </div>
  </section>

  <section class="section-title">
    <h2>最新文章</h2>
    <a href="/writing/">全部文章 →</a>
  </section>

  <div class="post-list">
    {posts.map((post) => (
      <article class="post-item">
        <div class="meta">{post.data.pubDate.toISOString().slice(0, 10)}</div>
        <a href={`/writing/${post.data.slug}/`}>{post.data.title}</a>
        <p>{post.data.description}</p>
        <div class="tags">{post.data.tags.map((tag) => <span class="tag">{tag}</span>)}</div>
      </article>
    ))}
  </div>
</BaseLayout>
