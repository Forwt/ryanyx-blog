---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('writing', ({ data }) => data.lang === 'zh' && data.draft !== true))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const projects = [
  {
    name: '一句话记账',
    summary: '自然语言记账与分账工具，把日常消费记录变成轻量、可复盘的数据。',
    stack: ['AI', 'Personal finance', 'Tooling'],
    status: 'Prototype',
    href: '/projects/one-sentence-ledger/'
  },
  {
    name: 'OpenClaw Agent',
    summary: '基于 LangChain / ReAct 的本地 AI Agent 实践，关注工具调用、权限边界和任务执行。',
    stack: ['LangChain', 'ReAct', 'Agent'],
    status: 'Building',
    href: '/projects/openclaw-agent/'
  },
  {
    name: 'Personal Blog',
    summary: '用 Astro、Markdown、GitHub 和 Cloudflare Pages 搭建的个人知识站。',
    stack: ['Astro', 'Markdown', 'Cloudflare'],
    status: 'Live',
    href: '/projects/personal-blog/'
  }
];
---
<BaseLayout title="Ryanzr" description="Ryan 的个人知识站：AI、投资、金融和小工具。" lang="zh" path="home">
  <section class="hero">
    <div class="eyebrow">AI · Investing · Finance · Small Tools</div>
    <h1>这里是 Wang Yuxin 的 blog ，记录一切值得记录的想法。</h1>
    <p class="lead">个人知识站。它用来沉淀文章、项目和长期思考。中文是原文，英文版本为译文。</p>
  </section>

  <section class="section">
    <div class="section-head">
      <h2>Featured Writing</h2>
      <a class="section-link" href="/writing/">全部文章</a>
    </div>
    <div class="stack">
      {posts.map((post) => (
        <article class="post-row">
          <div class="meta">{post.data.pubDate.toISOString().slice(0, 10)}</div>
          <a href={`/writing/${post.data.routeSlug}/`}>{post.data.title}</a>
          <p>{post.data.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-head">
      <h2>Projects</h2>
      <a class="section-link" href="/projects/">全部项目</a>
    </div>
    <div class="project-grid">
      {projects.map((project) => (
        <a class="project-card project-card-link" href={project.href}>
          <div class="project-top">
            <h3>{project.name}</h3>
            <span class="project-status">{project.status}</span>
          </div>
          <p>{project.summary}</p>
          <div class="tags">{project.stack.map((item) => <span class="tag">{item}</span>)}</div>
        </a>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-head">
      <h2>Contact / Links</h2>
    </div>
    <div class="link-list">
      <a href="https://github.com/Forwt">GitHub</a>
      <a href="/resume/">Resume</a>
      <a href="/about/">About</a>
    </div>
  </section>
</BaseLayout>
