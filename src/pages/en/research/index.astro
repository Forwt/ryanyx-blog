---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const reports = (await getCollection('research', ({ data }) => data.lang === 'en' && data.draft !== true))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const stanceLabel = {
  constructive: 'Constructive',
  neutral: 'Neutral',
  cautious: 'Cautious'
};
---
<BaseLayout
  title="Research"
  description="Market research grounded in public primary sources and institutional analysis."
  lang="en"
  path="research"
  switchTo="/research/"
>
  <section class="page-head research-index-head">
    <div class="eyebrow">Research / Evidence first</div>
    <h1>Research</h1>
  </section>

  <div class="research-list">
    {reports.map((report) => (
      <article class="research-card">
        <div class="research-card-top">
          <div class="meta">
            {report.data.pubDate.toISOString().slice(0, 10)} · {report.data.subject}
          </div>
          <span class={`research-stance ${report.data.stance}`}>
            {stanceLabel[report.data.stance]}
          </span>
        </div>
        <a class="research-card-title" href={`/en/research/${report.data.routeSlug}/`}>{report.data.title}</a>
        <p>{report.data.description}</p>
        <div class="research-card-footer">
          <div class="tags">{report.data.tags.map((tag) => <span class="tag">{tag}</span>)}</div>
          <span class="meta">{report.data.reportCount} institutional items · {report.data.readingTime}</span>
        </div>
      </article>
    ))}
  </div>
</BaseLayout>
