---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const reports = await getCollection('research', ({ data }) => data.lang === 'en' && data.draft !== true);
  return reports.map((report) => ({
    params: { slug: report.data.routeSlug },
    props: { report }
  }));
}

const { report } = Astro.props;
const counterparts = await getCollection('research', ({ data }) =>
  data.lang === 'zh' && data.translationKey === report.data.translationKey && data.draft !== true
);
const counterpart = counterparts[0];
const { Content, headings } = await render(report);
const toc = headings.filter((heading) => heading.depth === 2);
const toneLabel = { positive: '↑', neutral: '•', negative: '↓' };
---
<BaseLayout
  title={report.data.title}
  description={report.data.description}
  lang="en"
  path="research"
  switchTo={counterpart ? `/research/${counterpart.data.routeSlug}/` : '/research/'}
  image={report.data.image}
  publishedTime={report.data.pubDate.toISOString()}
>
  <article class="research-report">
    <header class="research-report-head">
      <a class="research-back" href="/en/research/">← Research index</a>
      <div class="eyebrow">Research Note · {report.data.subject}</div>
      <h1>{report.data.title}</h1>
      <p class="lead">{report.data.description}</p>
      {report.data.aiTranslated && <p class="translation-note">AI-translated from the Chinese original and editorially reviewed.</p>}
      <div class="research-meta-row">
        <span>Published {report.data.pubDate.toISOString().slice(0, 10)}</span>
        <span>Coverage {report.data.coverageStart.toISOString().slice(0, 10)} — {report.data.coverageEnd.toISOString().slice(0, 10)}</span>
        <span>{report.data.reportCount} institutional items</span>
        <span>{report.data.sourceCount} public sources</span>
        <span>{report.data.readingTime}</span>
      </div>
      <div class="metric-grid">
        {report.data.metrics.map((metric) => (
          <div class={`metric-card ${metric.tone}`}>
            <div class="metric-label">{toneLabel[metric.tone]} {metric.label}</div>
            <div class="metric-value">{metric.value}</div>
            <div class="metric-note">{metric.note}</div>
          </div>
        ))}
      </div>
    </header>

    <div class="research-layout">
      {toc.length > 0 && (
        <aside class="research-toc" aria-label="Report contents">
          <div class="research-toc-title">Contents</div>
          <nav>
            {toc.map((heading, index) => (
              <a href={`#${heading.slug}`}><span>{String(index + 1).padStart(2, '0')}</span>{heading.text}</a>
            ))}
          </nav>
        </aside>
      )}
      <div class="research-prose prose"><Content /></div>
    </div>
  </article>
</BaseLayout>
