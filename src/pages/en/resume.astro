---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Resume" description="Ryan's resume entry." lang="en" path="resume">
  <section class="page-head">
    <div class="eyebrow">Resume</div>
    <h1>Resume</h1>
    <p class="lead">A compact version for now. I will add formal PDF files, links, and fuller experience details later.</p>
  </section>
  <article class="prose">
    <h2>Education</h2>
    <ul class="resume-list">
      <li>Finance background, with ongoing practice in AI engineering and investment research.</li>
    </ul>
    <h2>Experience</h2>
    <ul class="resume-list">
      <li>Interested in bonds, HK/US equities, market liquidity, and investment research workflows.</li>
      <li>Turning finance observations into repeatable research and lightweight tools.</li>
    </ul>
    <h2>Projects</h2>
    <ul class="resume-list">
      <li>One-sentence Ledger, OpenClaw Agent, Personal Blog.</li>
    </ul>
    <h2>Skills</h2>
    <ul class="resume-list">
      <li>AI applications, investment research, Markdown writing, data organization, and personal tool building.</li>
    </ul>
  </article>
</BaseLayout>
