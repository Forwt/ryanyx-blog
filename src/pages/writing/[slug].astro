---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('writing', ({ data }) => data.lang === 'zh' && data.draft !== true);
  return posts.map((post) => ({
    params: { slug: post.data.routeSlug },
    props: { post }
  }));
}

const { post } = Astro.props;
const allPosts = await getCollection('writing');
const counterpart = allPosts.find((item) => item.data.lang === 'en' && item.data.translationKey === post.data.translationKey);
const { Content } = await render(post);
---
<BaseLayout
  title={post.data.title}
  description={post.data.description}
  lang="zh"
  path="writing"
  switchTo={counterpart ? `/en/writing/${counterpart.data.routeSlug}/` : '/en/writing/'}
  image={post.data.image}
  publishedTime={post.data.pubDate.toISOString()}
>
  <article class="prose">
    <header class="page-head">
      <div class="eyebrow">Writing / {post.data.pubDate.toISOString().slice(0, 10)}</div>
      <h1>{post.data.title}</h1>
      <p class="lead">{post.data.description}</p>
    </header>
    {post.data.image && <img class="writing-hero" src={post.data.image} alt={post.data.imageAlt ?? post.data.title} />}
    <Content />
  </article>
</BaseLayout>
