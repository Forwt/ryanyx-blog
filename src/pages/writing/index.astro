---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('writing', ({ data }) => data.lang === 'zh' && data.draft !== true))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<BaseLayout title="Writing" description="Ryan 的中文文章归档。" lang="zh" path="writing">
  <section class="page-head">
    <div class="eyebrow">Writing</div>
    <h1>文章</h1>
    <p class="lead">按时间倒序记录 AI 应用、投资判断、金融市场和个人工具构建。</p>
  </section>
  <div class="stack">
    {posts.map((post) => (
      <article class="post-row">
        <div class="meta">{post.data.pubDate.toISOString().slice(0, 10)}</div>
        <a href={`/writing/${post.data.routeSlug}/`}>{post.data.title}</a>
        <p>{post.data.description}</p>
        <div class="tags">{post.data.tags.map((tag) => <span class="tag">{tag}</span>)}</div>
      </article>
    ))}
  </div>
</BaseLayout>
