---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="简历" description="王宇新的教育与工作经历。" lang="zh" path="resume">
  <section class="page-head resume-head">
    <div class="eyebrow">Resume</div>
    <h1>王宇新</h1>
  </section>

  <article class="resume-simple">
    <section>
      <h2>教育经历</h2>
      <div class="resume-entry"><time>2023.09 - 2025.07</time><div><strong>香港大学</strong><span>金融工程学硕士</span></div></div>
      <div class="resume-entry"><time>2019.09 - 2023.06</time><div><strong>中山大学</strong><span>金融学学士</span></div></div>
    </section>

    <section>
      <h2>工作经历</h2>
      <div class="resume-entry"><time>2025.07 - 至今</time><div><strong>兴业银行北京分行</strong><span>管理培训生</span></div></div>
      <div class="resume-entry"><time>2025.01 - 2025.03</time><div><strong>中国银河证券总部</strong><span>债券交易实习生</span></div></div>
      <div class="resume-entry"><time>2024.12 - 2025.01</time><div><strong>時和資產管理有限公司</strong><span>投研实习生</span></div></div>
      <div class="resume-entry"><time>2024.09 - 2024.12</time><div><strong>南方基金</strong><span>机构业务部实习生</span></div></div>
      <div class="resume-entry"><time>2023.02 - 2023.05</time><div><strong>中信建投证券</strong><span>投行部实习生</span></div></div>
      <div class="resume-entry"><time>2021.06 - 2021.08</time><div><strong>中国银行</strong><span>公司金融部实习生</span></div></div>
    </section>
  </article>
</BaseLayout>
