---
interface Props {
  lang: 'zh' | 'en';
}

const { lang } = Astro.props;
const isEn = lang === 'en';
const copy = isEn
  ? {
      brand: 'Marginal Notes',
      nav: ['entries', 'archive', 'about'],
      title: ['Leave a little time', 'unoptimised'],
      date: 'written on July 23, 2026',
      paragraphs: [
        'I want to keep the good pages I happen upon. Not to seal them into screenshots, but to ask: what makes an interface feel quiet—and why does it make us willing to read a little longer?',
        'Maybe a good digital space is not always faster. It leaves edges where we can pause, a little unfilled room, and a landscape that asks for almost none of our attention.'
      ],
      filed: 'filed under',
      tags: ['frontend collection', 'reading experience'],
      theme: ['light', 'dark'],
      aria: 'Mist, Ink and Long-form Reading blog specimen'
    }
  : {
      brand: '余白备忘',
      nav: ['笔记', '归档', '关于'],
      title: ['留下一点', '不被优化的时间'],
      date: '写于 2026 年 7 月 23 日',
      paragraphs: [
        '我想把偶遇的好网页收集起来。不是把它们封进截图，而是试着理解：是什么让一个界面安静下来，又为什么它能让人愿意读完一段更长的文字。',
        '也许好的数字空间不总是更快。它会留下可停顿的边缘、不会被填满的空白，以及一张在背景里几乎不要求你注意的风景。'
      ],
      filed: '收录于',
      tags: ['前端收藏', '阅读体验'],
      theme: ['日间', '夜间'],
      aria: '雾、墨与长阅读的博客样张'
    };
---
<section class="inspiration-demo" data-inspiration-demo data-inspiration-theme="dark" aria-label={copy.aria}>
  <div class="inspiration-canvas-wrap" aria-hidden="true">
    <img class="inspiration-source" data-mist-source src="/frontend-collection/mist-ridge.png" alt="" />
    <canvas data-mist-canvas></canvas>
  </div>
  <div class="inspiration-shell">
    <div class="inspiration-nav">
      <a href={isEn ? '/en/' : '/'}>{copy.brand}</a>
      <nav aria-label={isEn ? 'Specimen navigation' : '样张导航'}>
        <a href="#essay">{copy.nav[0]}</a><a href="#notes">{copy.nav[1]}</a><a href="#source">{copy.nav[2]}</a>
      </nav>
    </div>
    <div class="inspiration-body" id="essay">
      <h2>{copy.title[0]}<br />{copy.title[1]}</h2>
      <p class="inspiration-date">{copy.date}</p>
      {copy.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
      <p class="inspiration-tags">{copy.filed} <a href="#notes">{copy.tags[0]}</a> · <a href="#notes">{copy.tags[1]}</a></p>
    </div>
    <footer class="inspiration-footer">
      <span>© 2026 Ryanyx</span>
      <span class="inspiration-theme-picker" role="group" aria-label={isEn ? 'Specimen color scheme' : '样张色彩方案'}>
        <button type="button" data-demo-theme="light" aria-pressed="false">{copy.theme[0]}</button> / <button type="button" data-demo-theme="dark" aria-pressed="true">{copy.theme[1]}</button>
      </span>
    </footer>
  </div>
</section>

<script>
  document.querySelectorAll('[data-inspiration-demo]').forEach((demo) => {
    const element = demo;
    const canvas = element.querySelector('[data-mist-canvas]');
    const source = element.querySelector('[data-mist-source]');
    const controls = element.querySelectorAll('[data-demo-theme]');
    if (!(canvas instanceof HTMLCanvasElement) || !(source instanceof HTMLImageElement)) return;

    const context = canvas.getContext('2d');
    if (!context) return;
    const sample = document.createElement('canvas');
    const sampleContext = sample.getContext('2d', { willReadFrequently: true });
    if (!sampleContext) return;
    const bayer = [0, 8, 2, 10, 12, 4, 14, 6, 3, 11, 1, 9, 15, 7, 13, 5];
    const palette = () => element.dataset.inspirationTheme === 'dark'
      ? { background: '#111111', ink: '#ead9bf' }
      : { background: '#fff8ec', ink: '#8a541c' };

    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
    let animationFrame = 0;
    let lastFrame = 0;
    let isVisible = true;

    const draw = (time = 0) => {
      if (!source.complete || !source.naturalWidth) return;
      const rect = canvas.getBoundingClientRect();
      const ratio = Math.min(window.devicePixelRatio || 1, 1.25);
      const width = Math.max(1, Math.floor(rect.width * ratio));
      const height = Math.max(1, Math.floor(rect.height * ratio));
      if (canvas.width !== width || canvas.height !== height) { canvas.width = width; canvas.height = height; }
      if (sample.width !== width || sample.height !== height) { sample.width = width; sample.height = height; }
      const colors = palette();
      context.setTransform(1, 0, 0, 1, 0, 0);
      context.fillStyle = colors.background;
      context.fillRect(0, 0, width, height);
      sampleContext.clearRect(0, 0, width, height);
      const imageRatio = source.naturalWidth / source.naturalHeight;
      const targetRatio = width / height;
      const cropWidth = imageRatio > targetRatio ? source.naturalHeight * targetRatio : source.naturalWidth;
      const cropHeight = imageRatio > targetRatio ? source.naturalHeight : source.naturalWidth / targetRatio;
      const cropX = (source.naturalWidth - cropWidth) / 2;
      const cropY = Math.max(0, (source.naturalHeight - cropHeight) * .52);
      sampleContext.filter = 'grayscale(1) contrast(1.55) brightness(1.08)';
      const maximumPan = Math.round(9 * ratio);
      const pan = reducedMotion.matches
        ? 0
        : ((Math.sin(time / 9000) + 1) / 2) * maximumPan;
      sampleContext.drawImage(
        source,
        cropX,
        cropY,
        cropWidth,
        cropHeight,
        -pan,
        0,
        width + maximumPan,
        height,
      );
      sampleContext.filter = 'none';
      const pixels = sampleContext.getImageData(0, 0, width, height).data;
      const step = Math.max(3, Math.round(3 * ratio));
      const dot = Math.max(2, Math.round(2 * ratio));
      context.fillStyle = colors.ink;
      const phase = reducedMotion.matches ? 0 : Math.floor(time / 900) % 4;
      for (let y = 0; y < height; y += step) {
        for (let x = 0; x < width; x += step) {
          const position = (Math.min(height - 1, y) * width + Math.min(width - 1, x)) * 4;
          const luminance = (pixels[position] * .2126 + pixels[position + 1] * .7152 + pixels[position + 2] * .0722) / 255;
          const threshold = (bayer[(((Math.floor(y / step) + phase) & 3) * 4) + ((Math.floor(x / step) + phase) & 3)] + .5) / 16;
          const fadeLeft = Math.min(1, x / (width * .15));
          const visibility = luminance * fadeLeft;
          if (visibility > threshold) {
            context.globalAlpha = Math.min(.98, .35 + visibility * .78);
            context.fillRect(x, y, dot, dot);
          }
        }
      }
      context.globalAlpha = 1;
    };
    const stopAnimation = () => {
      if (animationFrame) {
        cancelAnimationFrame(animationFrame);
        animationFrame = 0;
      }
    };
    const animate = (time) => {
      if (!isVisible || reducedMotion.matches) return;
      if (time - lastFrame >= 83) {
        draw(time);
        lastFrame = time;
      }
      animationFrame = requestAnimationFrame(animate);
    };
    const render = () => {
      stopAnimation();
      const now = performance.now();
      draw(now);
      lastFrame = now;
      if (isVisible && !reducedMotion.matches) {
        animationFrame = requestAnimationFrame(animate);
      }
    };
    controls.forEach((control) => control.addEventListener('click', () => {
      const theme = control.getAttribute('data-demo-theme'); if (!theme) return;
      element.dataset.inspirationTheme = theme;
      controls.forEach((button) => button.setAttribute('aria-pressed', String(button === control)));
      render();
    }));
    source.addEventListener('load', render, { once: true });
    window.addEventListener('resize', render, { passive: true });
    reducedMotion.addEventListener('change', render);
    const observer = new IntersectionObserver((entries) => {
      isVisible = entries[0]?.isIntersecting ?? true;
      if (isVisible) render();
      else stopAnimation();
    }, { threshold: 0 });
    observer.observe(canvas);
    render();
  });
</script>
